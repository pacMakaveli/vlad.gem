<% content_for :title, "Response Drift - #{@conversation.title}" %>

<div class="mb-8">
  <%= link_to "← Back to #{@conversation.title}", conversation_path(@conversation), class: "text-purple-600 hover:text-purple-700" %>
</div>

<h1 class="text-3xl font-bold text-gray-900 mb-2">Response Drift</h1>
<p class="text-gray-600 mb-8">How response patterns change over time</p>

<!-- Average Response Times by Participant -->
<div class="bg-white rounded-lg shadow-sm p-6 mb-8">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Average Response Times</h2>
  <div class="space-y-4">
    <% @response_times.each do |data| %>
      <div class="flex items-center justify-between p-4 bg-gray-50 rounded">
        <span class="font-medium text-gray-900"><%= data[:participant] %></span>
        <div class="text-right">
          <div class="text-2xl font-bold text-gray-900"><%= data[:avg_response_time_formatted] %></div>
          <div class="text-sm text-gray-500">avg response time</div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Initiation Trends -->
<% if @initiation_trend.any? %>
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Who Starts Conversations</h2>
    <p class="text-sm text-gray-500 mb-4">Conversation initiations over the last 60 days</p>
    <div style="height: 300px;">
      <canvas
        data-controller="chart"
        data-chart-type-value="bar"
        data-chart-data-value='<%= chart_data_for_initiations(@initiation_trend).to_json %>'
      ></canvas>
    </div>
  </div>
<% end %>


<% content_for :title, "Daily Rhythm - #{@conversation.title}" %>

<div class="mb-8">
  <%= link_to "← Back to #{@conversation.title}", conversation_path(@conversation), class: "text-purple-600 hover:text-purple-700" %>
</div>

<h1 class="text-3xl font-bold text-gray-900 mb-2">Daily Rhythm</h1>
<p class="text-gray-600 mb-8">When do you chat the most?</p>

<!-- Hourly Heatmap -->
<div class="bg-white rounded-lg shadow-sm p-6 mb-8">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Activity by Hour of Day</h2>
  <div style="height: 300px;">
    <canvas
      data-controller="chart"
      data-chart-type-value="bar"
      data-chart-data-value='<%= chart_data_for_hourly(@hourly_heatmap).to_json %>'
    ></canvas>
  </div>
</div>

<!-- Day of Week Distribution -->
<% if @day_of_week.any? %>
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Activity by Day of Week</h2>
    <div style="height: 300px;">
      <canvas
        data-controller="chart"
        data-chart-type-value="bar"
        data-chart-data-value='<%= chart_data_for_day_of_week(@day_of_week).to_json %>'
      ></canvas>
    </div>
  </div>
<% end %>


<% content_for :title, "Shift - #{@conversation.title}" %>

<div class="mb-8">
  <%= link_to "← Back to #{@conversation.title}", conversation_path(@conversation), class: "text-purple-600 hover:text-purple-700" %>
</div>

<h1 class="text-3xl font-bold text-gray-900 mb-2">Shift</h1>
<p class="text-gray-600 mb-8">How sentiment and response patterns change over time</p>

<!-- Time Range Selector -->
<div class="mb-6">
  <div class="inline-flex rounded-lg border border-gray-300 bg-white p-1">
    <%= link_to "7 Days", conversation_shift_path(@conversation, days: 7), class: "px-4 py-2 rounded #{params[:days] == '7' ? 'bg-purple-600 text-white' : 'text-gray-700 hover:bg-gray-50'}" %>
    <%= link_to "30 Days", conversation_shift_path(@conversation, days: 30), class: "px-4 py-2 rounded #{params[:days].nil? || params[:days] == '30' ? 'bg-purple-600 text-white' : 'text-gray-700 hover:bg-gray-50'}" %>
    <%= link_to "90 Days", conversation_shift_path(@conversation, days: 90), class: "px-4 py-2 rounded #{params[:days] == '90' ? 'bg-purple-600 text-white' : 'text-gray-700 hover:bg-gray-50'}" %>
  </div>
</div>

<!-- Sentiment Trend -->
<div class="bg-white rounded-lg shadow-sm p-6 mb-8">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Sentiment Over Time</h2>
  <p class="text-sm text-gray-500 mb-4">How the emotional tone of your conversation evolves</p>
  <div style="height: 300px;">
    <canvas
      data-controller="chart"
      data-chart-type-value="line"
      data-chart-data-value='<%= chart_data_for_sentiment(@sentiment_trend).to_json %>'
    ></canvas>
  </div>
  <div class="mt-4 flex items-center justify-center space-x-8 text-sm">
    <div class="flex items-center">
      <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
      <span>Negative (-1.0)</span>
    </div>
    <div class="flex items-center">
      <div class="w-3 h-3 rounded-full bg-gray-400 mr-2"></div>
      <span>Neutral (0.0)</span>
    </div>
    <div class="flex items-center">
      <div class="w-3 h-3 rounded-full bg-green-500 mr-2"></div>
      <span>Positive (1.0)</span>
    </div>
  </div>
</div>

<!-- Response Time Trend -->
<div class="bg-white rounded-lg shadow-sm p-6">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Response Time Drift</h2>
  <p class="text-sm text-gray-500 mb-4">How quickly you respond to each other over time</p>
  <div style="height: 300px;">
    <canvas
      data-controller="chart"
      data-chart-type-value="line"
      data-chart-data-value='<%= chart_data_for_response_time(@response_time_trend).to_json %>'
    ></canvas>
  </div>
</div>


<% content_for :title, "New Since Last Import - #{@conversation.title}" %>

<div class="mb-8">
  <%= link_to "← Back to #{@conversation.title}", conversation_path(@conversation), class: "text-purple-600 hover:text-purple-700" %>
</div>

<h1 class="text-3xl font-bold text-gray-900 mb-2">New Since Last Import</h1>
<p class="text-gray-600 mb-8">Messages added in the most recent import</p>

<% if @latest_import %>
  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="font-semibold text-blue-900">Latest Import</h3>
        <p class="text-sm text-blue-700">
          <%= @latest_import.created_at.strftime("%B %d, %Y at %I:%M %p") %>
        </p>
      </div>
      <div class="text-right">
        <div class="text-2xl font-bold text-blue-900"><%= @latest_import.new_messages_count %></div>
        <div class="text-sm text-blue-700">new messages</div>
      </div>
    </div>
  </div>

  <% if @new_messages.any? %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="space-y-6">
        <% @new_messages.each do |message| %>
          <div class="border-l-4 <%= participant_color(message.participant) %> pl-4 py-2 bg-green-50">
            <div class="flex items-start justify-between mb-1">
              <div>
                <span class="font-medium text-gray-900"><%= message.participant.name %></span>
                <span class="ml-2 inline-block text-xs px-2 py-1 rounded bg-green-200 text-green-800">
                  NEW
                </span>
                <% if message.sentiment_label %>
                  <span class="ml-1 inline-block text-xs px-2 py-1 rounded <%= sentiment_badge_color(message.sentiment_label) %>">
                    <%= message.sentiment_label %>
                  </span>
                <% end %>
              </div>
              <span class="text-sm text-gray-500"><%= message.sent_at.strftime("%b %d, %Y %I:%M %p") %></span>
            </div>

            <% if message.message_type == "text" %>
              <p class="text-gray-700 whitespace-pre-wrap"><%= message.content %></p>
            <% elsif message.message_type == "media" %>
              <p class="text-gray-500 italic">
                <%= message.media_type&.capitalize || "Media" %> <%= message.content %>
              </p>
            <% elsif message.message_type == "system" %>
              <p class="text-gray-400 text-sm italic"><%= message.content %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-sm p-12 text-center">
      <p class="text-gray-500">No new messages in this import</p>
    </div>
  <% end %>
<% else %>
  <div class="bg-white rounded-lg shadow-sm p-12 text-center">
    <p class="text-gray-500">No imports yet</p>
  </div>
<% end %>

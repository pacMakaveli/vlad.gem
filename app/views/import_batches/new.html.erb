<% content_for :title, "Import Chat - #{@conversation.title}" %>

<div class="mb-8">
  <%= link_to "← Back to #{@conversation.title}", conversation_path(@conversation), class: "text-purple-600 hover:text-purple-700" %>
</div>

<div class="max-w-2xl">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Import WhatsApp Chat</h1>
  <p class="text-gray-600 mb-8">Upload an exported WhatsApp chat file. The app will automatically detect and skip duplicate messages.</p>

  <div class="bg-blue-50 border border-blue-200 p-4 rounded-lg mb-8">
    <h3 class="font-semibold text-blue-900 mb-2">How to export from WhatsApp:</h3>
    <ol class="list-decimal list-inside text-blue-800 space-y-1 text-sm">
      <li>Open the chat in WhatsApp</li>
      <li>Tap the three dots (⋮) menu</li>
      <li>Select "More" → "Export chat"</li>
      <li>Choose "Without media" (recommended)</li>
      <li>Upload the .txt file here</li>
    </ol>
  </div>

  <%= form_with(model: [@conversation, @import_batch], class: "space-y-6") do |form| %>
    <% if @import_batch.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded">
        <h2 class="font-semibold mb-2"><%= pluralize(@import_batch.errors.count, "error") %> occurred:</h2>
        <ul class="list-disc list-inside">
          <% @import_batch.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :file, "WhatsApp Export File (.txt)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-purple-400 transition">
        <%= form.file_field :file,
          accept: ".txt",
          required: true,
          class: "block w-full text-sm text-gray-500
            file:mr-4 file:py-2 file:px-4
            file:rounded-full file:border-0
            file:text-sm file:font-semibold
            file:bg-purple-50 file:text-purple-700
            hover:file:bg-purple-100" %>
        <p class="mt-2 text-xs text-gray-500">Only .txt files are accepted</p>
      </div>
    </div>

    <div class="bg-yellow-50 border border-yellow-200 p-4 rounded-lg">
      <p class="text-sm text-yellow-800">
        <strong>Note:</strong> Full exports can be re-imported safely. The app will automatically detect and skip duplicate messages while preserving historical data.
      </p>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", conversation_path(@conversation), class: "px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50" %>
      <%= form.submit "Start Import", class: "px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700" %>
    </div>
  <% end %>
</div>

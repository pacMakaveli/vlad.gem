<% content_for :title, "Conversations - Vlad's Gem 💎" %>

<div class="flex justify-between items-center mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Your Conversations</h1>
  <%= link_to "New Conversation", new_conversation_path, class: "bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700" %>
</div>

<% if @conversations.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @conversations.each do |conversation| %>
      <div class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition">
        <h2 class="text-xl font-semibold text-gray-900 mb-2">
          <%= link_to conversation.title, conversation_path(conversation), class: "hover:text-purple-600" %>
        </h2>

        <% if conversation.description.present? %>
          <p class="text-gray-600 mb-4"><%= conversation.description %></p>
        <% end %>

        <div class="space-y-2 text-sm text-gray-500">
          <div class="flex items-center justify-between">
            <span>Total messages:</span>
            <span class="font-medium"><%= conversation.total_messages_count %></span>
          </div>

          <% if conversation.first_message_at %>
            <div class="flex items-center justify-between">
              <span>Period:</span>
              <span class="font-medium">
                <%= conversation.first_message_at.strftime("%b %Y") %> -
                <%= conversation.last_message_at.strftime("%b %Y") %>
              </span>
            </div>
          <% end %>

          <div class="flex items-center justify-between">
            <span>Imports:</span>
            <span class="font-medium"><%= conversation.import_batches.completed.count %></span>
          </div>
        </div>

        <div class="mt-4 pt-4 border-t flex justify-between items-center">
          <%= link_to "View Analytics", conversation_path(conversation), class: "text-purple-600 hover:text-purple-700 font-medium" %>
          <%= link_to "Import", new_conversation_import_batch_path(conversation), class: "text-gray-600 hover:text-gray-700" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-lg shadow-sm p-12 text-center">
    <p class="text-gray-500 text-lg mb-6">No conversations yet. Create your first conversation to get started!</p>
    <%= link_to "Create Conversation", new_conversation_path, class: "bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 inline-block" %>
  </div>
<% end %>
